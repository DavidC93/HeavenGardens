# Server-only Neon connection string for Netlify Functions and local scripts.
# Do not expose this in browser code.
DATABASE_URL=
NETLIFY_DATABASE_URL=

# Optional password reset email provider.
# Resend can be connected later; leave empty to keep reset URLs as a dev fallback.
RESEND_API_KEY=
PASSWORD_RESET_FROM=
SITE_URL=https://heaven-gardens.netlify.app
